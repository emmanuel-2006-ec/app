    <script>
        // ============================================================
        //  DATA LAYER — localStorage
        // ============================================================
        const DB = {
            getUsers() { return JSON.parse(localStorage.getItem('mzuni_users') || '[]'); },
            setUsers(u) { localStorage.setItem('mzuni_users', JSON.stringify(u)); },
            getPosts() { return JSON.parse(localStorage.getItem('mzuni_posts') || '[]'); },
            setPosts(p) { localStorage.setItem('mzuni_posts', JSON.stringify(p)); },
            getMessages() { return JSON.parse(localStorage.getItem('mzuni_messages') || '[]'); },
            setMessages(m) { localStorage.setItem('mzuni_messages', JSON.stringify(m)); },
            getCurrentUser() {
                const data = JSON.parse(sessionStorage.getItem('mzuni_session') || 'null');
                return data;
            },
            setCurrentUser(u) { sessionStorage.setItem('mzuni_session', JSON.stringify(u)); },
            clearSession() { sessionStorage.removeItem('mzuni_session'); }
        };

        // ============================================================
        //  HELPERS
        // ============================================================
        function generateId() { return Date.now().toString(36) + Math.random().toString(36).slice(2, 7); }

        function timeAgo(date) {
            const diff = Date.now() - new Date(date).getTime();
            const mins = Math.floor(diff / 60000);
            if (mins < 1) return 'Just now';
            if (mins < 60) return mins + 'm ago';
            const hrs = Math.floor(mins / 60);
            if (hrs < 24) return hrs + 'h ago';
            const days = Math.floor(hrs / 24);
            if (days < 7) return days + 'd ago';
            return new Date(date).toLocaleDateString();
        }

        function getYearEmoji(year) {
            const map = {
                'First Year': '1️⃣',
                'Second Year': '2️⃣',
                'Third Year': '3️⃣',
                'Fourth Year': '4️⃣',
                'Fifth Year': '5️⃣'
            };
            return map[year] || '🎓';
        }

        function getDefaultAvatar() {
            return 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"%3E%3Ccircle cx="50" cy="50" r="50" fill="%231a472a"/%3E%3Ctext x="50" y="62" font-size="40" text-anchor="middle" fill="%23f5c842" font-family="Arial"%3E🎓%3C/text%3E%3C/svg%3E';
        }

        // ============================================================
        //  AUTH
        // ============================================================
        function switchPage(pageId) {
            document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
        }

        // Login
        document.getElementById('loginBtn').addEventListener('click', () => {
            const email = document.getElementById('loginEmail').value.trim();
            const password = document.getElementById('loginPassword').value.trim();
            const errEl = document.getElementById('loginError');
            errEl.classList.remove('show');
            if (!email || !password) { errEl.textContent = 'Please fill in all fields.';
                errEl.classList.add('show'); return; }
            const users = DB.getUsers();
            const found = users.find(u => u.email === email && u.password === password);
            if (!found) { errEl.textContent = 'Invalid email or password.';
                errEl.classList.add('show'); return; }
            // update online status
            found.isOnline = true;
            found.lastSeen = new Date().toISOString();
            DB.setUsers(users);
            DB.setCurrentUser(found);
            enterDashboard(found);
        });

        document.getElementById('loginPassword').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById(
                'loginBtn').click(); });
        document.getElementById('loginEmail').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById(
                'loginBtn').click(); });

        // Signup
        document.getElementById('signupBtn').addEventListener('click', () => {
            const username = document.getElementById('signupUsername').value.trim();
            const email = document.getElementById('signupEmail').value.trim();
            const password = document.getElementById('signupPassword').value.trim();
            const year = document.getElementById('signupYear').value;
            const errEl = document.getElementById('signupError');
            errEl.classList.remove('show');
            if (!username || !email || !password || !year) {
                errEl.textContent = 'All fields are mandatory.';
                errEl.classList.add('show');
                return;
            }
            if (password.length < 6) {
                errEl.textContent = 'Password must be at least 6 characters.';
                errEl.classList.add('show');
                return;
            }
            const users = DB.getUsers();
            if (users.find(u => u.email === email)) {
                errEl.textContent = 'Email already registered.';
                errEl.classList.add('show');
                return;
            }
            if (users.find(u => u.username.toLowerCase() === username.toLowerCase())) {
                errEl.textContent = 'Username already taken.';
                errEl.classList.add('show');
                return;
            }
            // profile pic
            const fileInput = document.getElementById('profilePicInput');
            let avatar = getDefaultAvatar();
            if (fileInput.files && fileInput.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) { avatar = e.target.result;
                    finishSignup(avatar); };
                reader.readAsDataURL(fileInput.files[0]);
            } else {
                finishSignup(avatar);
            }

            function finishSignup(avatarUrl) {
                const newUser = {
                    id: generateId(),
                    username,
                    email,
                    password,
                    yearOfStudy: year,
                    profilePic: avatarUrl,
                    isOnline: true,
                    lastSeen: new Date().toISOString(),
                    bio: '',
                    location: '',
                    interests: '',
                    createdAt: new Date().toISOString()
                };
                const users2 = DB.getUsers();
                users2.push(newUser);
                DB.setUsers(users2);
                DB.setCurrentUser(newUser);
                // Add welcome post
                const posts = DB.getPosts();
                posts.push({
                    id: generateId(),
                    userId: newUser.id,
                    username: newUser.username,
                    userProfilePic: newUser.profilePic,
                    content: `🎉 Hey everyone! I just joined Mzuzu Hub! Can't wait to connect with all of you. #MzuzuUniversity #NewBeginnings`,
                    type: 'text',
                    stickerType: null,
                    audioUrl: null,
                    videoUrl: null,
                    likes: [],
                    comments: [],
                    createdAt: new Date().toISOString()
                });
                DB.setPosts(posts);
                enterDashboard(newUser);
            }
        });

        // Switch between login/signup
        document.getElementById('goToSignup').addEventListener('click', () => switchPage('signupPage'));
        document.getElementById('goToLogin').addEventListener('click', () => switchPage('loginPage'));

        // ============================================================
        //  DASHBOARD ENTRY
        // ============================================================
        function enterDashboard(user) {
            switchPage('dashboardPage');
            renderDashboard(user);
        }

        let currentUser = null;
        let currentChatTarget = null;

        function renderDashboard(user) {
            currentUser = user;
            // update header
            document.getElementById('dashAvatar').src = user.profilePic || getDefaultAvatar();
            document.getElementById('dashUsername').textContent = user.username;
            document.getElementById('postUserAvatar').src = user.profilePic || getDefaultAvatar();

            // load posts
            renderPosts();
            renderOnlineUsers('all');
            renderChatList();
            renderVideos();

            // set up listeners
            setupEventListeners(user);
        }

        // ============================================================
        //  RENDER POSTS
        // ============================================================
        function renderPosts(containerId = 'postsContainer') {
            const container = document.getElementById(containerId);
            if (!container) return;
            const posts = DB.getPosts().sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
            if (posts.length === 0) {
                container.innerHTML =
                    `<div class="empty-state"><i class="fas fa-pen-fancy"></i><h3>No posts yet</h3><p>Be the first to share something!</p></div>`;
                return;
            }
            let html = '';
            posts.forEach(post => {
                const isLiked = post.likes && post.likes.includes(currentUser.id);
                const likeCount = post.likes ? post.likes.length : 0;
                const comments = post.comments || [];
                html += `
                    <div class="post-card" data-postid="${post.id}">
                        <div class="post-header">
                            <img src="${post.userProfilePic || getDefaultAvatar()}" alt="" />
                            <div class="post-user">
                                <div class="pname">${post.username} <span style="font-size:11px;color:#6a7a8a;font-weight:400;">${getYearEmoji(post.userYear || '')}</span></div>
                                <div class="ptime">${timeAgo(post.createdAt)}</div>
                            </div>
                        </div>
                        <div class="post-content">
                            ${post.type === 'sticker' ? `<span class="sticker-display">${post.content}</span>` : ''}
                            ${post.type === 'text' ? `<p>${post.content}</p>` : ''}
                            ${post.type === 'audio' ? `
                                <div class="audio-display">
                                    <button onclick="playAudio('${post.id}')"><i class="fas fa-play"></i></button>
                                    <span style="font-size:13px;font-weight:500;">🎵 Audio message</span>
                                    <span style="font-size:12px;color:#6a7a8a;margin-left:auto;">${post.audioDuration || '0:05'}</span>
                                </div>
                            ` : ''}
                            ${post.type === 'video' && post.videoUrl ? `
                                <div style="margin:8px 0;">
                                    <video controls style="max-width:100%;border-radius:16px;max-height:360px;width:100%;background:#000;">
                                        <source src="${post.videoUrl}" type="video/mp4" />
                                        Your browser does not support video.
                                    </video>
                                </div>
                            ` : ''}
                        </div>
                        <div class="post-actions">
                            <button class="${isLiked ? 'liked' : ''}" onclick="toggleLike('${post.id}')">
                                <i class="fas fa-heart"></i> ${likeCount > 0 ? likeCount : ''} Like
                            </button>
                            <button onclick="toggleComments('${post.id}')"><i class="fas fa-comment"></i> ${comments.length} Comment${comments.length !== 1 ? 's' : ''}</button>
                        </div>
                        <div class="post-comments" id="comments-${post.id}" style="display:${comments.length > 0 ? 'block' : 'none'};">
                            ${comments.map(c => `
                                <div class="comment-item">
                                    <img src="${c.profilePic || getDefaultAvatar()}" alt="" />
                                    <div class="cbody"><strong>${c.username}</strong> ${c.text}</div>
                                </div>
                            `).join('')}
                            <div class="comment-input">
                                <input type="text" placeholder="Write a comment..." id="commentInput-${post.id}" />
                                <button onclick="addComment('${post.id}')">Post</button>
                            </div>
                        </div>
                    </div>
                `;
            });
            container.innerHTML = html;
            // Also update allPostsContainer if it exists
            const allContainer = document.getElementById('allPostsContainer');
            if (allContainer && containerId === 'postsContainer') {
                allContainer.innerHTML = container.innerHTML;
            }
        }

        // ============================================================
        //  POST INTERACTIONS
        // ============================================================
        window.toggleLike = function(postId) {
            const posts = DB.getPosts();
            const post = posts.find(p => p.id === postId);
            if (!post) return;
            if (!post.likes) post.likes = [];
            const idx = post.likes.indexOf(currentUser.id);
            if (idx > -1) post.likes.splice(idx, 1);
            else post.likes.push(currentUser.id);
            DB.setPosts(posts);
            renderPosts();
        };

        window.addComment = function(postId) {
            const input = document.getElementById(`commentInput-${postId}`);
            if (!input || !input.value.trim()) return;
            const posts = DB.getPosts();
            const post = posts.find(p => p.id === postId);
            if (!post) return;
            if (!post.comments) post.comments = [];
            post.comments.push({
                username: currentUser.username,
                profilePic: currentUser.profilePic,
                text: input.value.trim(),
                createdAt: new Date().toISOString()
            });
            DB.setPosts(posts);
            input.value = '';
            renderPosts();
        };

        window.toggleComments = function(postId) {
            const el = document.getElementById(`comments-${postId}`);
            if (el) el.style.display = el.style.display === 'none' ? 'block' : 'none';
        };

        window.playAudio = function(postId) {
            // Simulate audio playback
            const posts = DB.getPosts();
            const post = posts.find(p => p.id === postId);
            if (!post) return;
            alert('🔊 Playing audio message (simulated)');
        };

        // ============================================================
        //  CREATE POST
        // ============================================================
        let selectedSticker = null;
        let recordedAudioBlob = null;
        let recordedAudioDuration = '0:05';

        document.getElementById('toggleStickerPicker').addEventListener('click', () => {
            const picker = document.getElementById('stickerPicker');
            picker.classList.toggle('open');
        });

        document.querySelectorAll('.sticker-emoji').forEach(el => {
            el.addEventListener('click', function() {
                selectedSticker = this.dataset.sticker;
                document.getElementById('postInput').value = `Sticker: ${selectedSticker}`;
                document.getElementById('stickerPicker').classList.remove('open');
            });
        });

        // Audio recording
        let mediaRecorder = null;
        let audioChunks = [];
        let isRecording = false;

        document.getElementById('audioRecordBtn').addEventListener('click', async () => {
            const btn = document.getElementById('audioRecordBtn');
            if (isRecording) {
                // Stop recording
                if (mediaRecorder) mediaRecorder.stop();
                isRecording = false;
                btn.innerHTML = '<i class="fas fa-microphone"></i> Audio';
                btn.style.color = '#e74c3c';
                return;
            }
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                mediaRecorder = new MediaRecorder(stream);
                audioChunks = [];
                mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
                mediaRecorder.onstop = () => {
                    const blob = new Blob(audioChunks, { type: 'audio/webm' });
                    recordedAudioBlob = blob;
                    recordedAudioDuration = '0:0' + Math.floor(blob.size / 10000);
                    btn.innerHTML = '<i class="fas fa-check-circle"></i> Audio Ready';
                    btn.style.color = '#2ecc71';
                    document.getElementById('postInput').value = '🎙️ Audio message attached';
                };
                mediaRecorder.start();
                isRecording = true;
                btn.innerHTML = '<i class="fas fa-stop-circle"></i> Stop';
                btn.style.color = '#e74c3c';
            } catch (e) {
                alert('Microphone access denied. Please allow microphone permissions.');
            }
        });

        // Video upload
        document.getElementById('videoUploadBtn').addEventListener('click', () => {
            document.getElementById('videoFileInput').click();
        });
        let uploadedVideoData = null;

        document.getElementById('videoFileInput').addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    uploadedVideoData = e.target.result;
                    document.getElementById('postInput').value = '🎬 Video attached';
                    document.getElementById('videoUploadBtn').innerHTML =
                        '<i class="fas fa-check-circle"></i> Video Ready';
                    document.getElementById('videoUploadBtn').style.color = '#2ecc71';
                };
                reader.readAsDataURL(this.files[0]);
            }
        });

        // Submit post
        document.getElementById('submitPostBtn').addEventListener('click', () => {
            const input = document.getElementById('postInput');
            let content = input.value.trim();
            let type = 'text';
            let stickerType = null;
            let audioUrl = null;
            let videoUrl = null;

            // Determine post type
            if (selectedSticker) {
                type = 'sticker';
                content = selectedSticker;
                stickerType = selectedSticker;
            } else if (recordedAudioBlob) {
                type = 'audio';
                // Convert blob to data URL
                const reader = new FileReader();
                reader.onload = function(e) {
                    audioUrl = e.target.result;
                    finalizePost('audio', content || '🎵 Audio message', null, audioUrl, null);
                };
                reader.readAsDataURL(recordedAudioBlob);
                return;
            } else if (uploadedVideoData) {
                type = 'video';
                videoUrl = uploadedVideoData;
                finalizePost('video', content || '🎬 Video post', null, null, videoUrl);
                return;
            }

            if (!content && type === 'text') {
                alert('Please write something or add media.');
                return;
            }
            finalizePost(type, content, stickerType, null, null);
        });

        function finalizePost(type, content, stickerType, audioUrl, videoUrl) {
            const posts = DB.getPosts();
            posts.push({
                id: generateId(),
                userId: currentUser.id,
                username: currentUser.username,
                userProfilePic: currentUser.profilePic,
                userYear: currentUser.yearOfStudy,
                content: content,
                type: type,
                stickerType: stickerType,
                audioUrl: audioUrl,
                videoUrl: videoUrl,
                audioDuration: recordedAudioDuration,
                likes: [],
                comments: [],
                createdAt: new Date().toISOString()
            });
            DB.setPosts(posts);
            // Reset
            document.getElementById('postInput').value = '';
            selectedSticker = null;
            recordedAudioBlob = null;
            uploadedVideoData = null;
            document.getElementById('stickerPicker').classList.remove('open');
            document.getElementById('audioRecordBtn').innerHTML = '<i class="fas fa-microphone"></i> Audio';
            document.getElementById('audioRecordBtn').style.color = '';
            document.getElementById('videoUploadBtn').innerHTML = '<i class="fas fa-film"></i> Video';
            document.getElementById('videoUploadBtn').style.color = '';
            document.getElementById('videoFileInput').value = '';
            renderPosts();
            // Also update other tabs
            renderPosts('allPostsContainer');
            renderVideos();
        }

        // ============================================================
        //  RENDER ONLINE USERS (by year)
        // ============================================================
        let currentYearFilter = 'all';

        function renderOnlineUsers(yearFilter = 'all') {
            currentYearFilter = yearFilter;
            const users = DB.getUsers();
            const container = document.getElementById('onlineUserList');
            if (!container) return;

            // Sort online first, then by year
            let filtered = users.filter(u => u.id !== currentUser.id);
            if (yearFilter !== 'all') {
                filtered = filtered.filter(u => u.yearOfStudy === yearFilter);
            }
            // Show online first
            filtered.sort((a, b) => {
                if (a.isOnline && !b.isOnline) return -1;
                if (!a.isOnline && b.isOnline) return 1;
                return a.username.localeCompare(b.username);
            });

            if (filtered.length === 0) {
                container.innerHTML = `<div style="padding:16px;text-align:center;color:#6a7a8a;font-size:13px;">No users in this year</div>`;
                return;
            }

            let html = '';
            filtered.forEach(u => {
                const online = u.isOnline || false;
                html += `
                    <button class="user-item" onclick="openChat('${u.id}')">
                        <img src="${u.profilePic || getDefaultAvatar()}" alt="" />
                        <div class="uinfo">
                            <div class="uname">${u.username}</div>
                            <div class="uyear">${u.yearOfStudy || 'N/A'} ${online ? '• Online' : ''}</div>
                        </div>
                        <span class="${online ? 'online-badge' : 'offline-badge'}"></span>
                    </button>
                `;
            });
            container.innerHTML = html;
        }

        // Year tabs
        document.querySelectorAll('.year-tab').forEach(tab => {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.year-tab').forEach(t => t.classList.remove('active'));
                this.classList.add('active');
                renderOnlineUsers(this.dataset.year);
            });
        });

        // ============================================================
        //  CHAT SYSTEM
        // ============================================================
        function renderChatList() {
            const container = document.getElementById('chatList');
            if (!container) return;
            const users = DB.getUsers().filter(u => u.id !== currentUser.id);
            const messages = DB.getMessages();

            if (users.length === 0) {
                container.innerHTML = `<div class="empty-state"><i class="fas fa-comment-dots"></i><h3>No chats yet</h3><p>Start a conversation with someone!</p></div>`;
                return;
            }

            let html = '';
            users.forEach(u => {
                const lastMsg = messages.filter(m =>
                    (m.fromUserId === currentUser.id && m.toUserId === u.id) ||
                    (m.fromUserId === u.id && m.toUserId === currentUser.id)
                ).sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt))[0];

                const msgPreview = lastMsg ? lastMsg.content : 'No messages yet';
                const time = lastMsg ? timeAgo(lastMsg.createdAt) : '';
                html += `
                    <div class="chat-item" onclick="openChat('${u.id}')">
                        <img src="${u.profilePic || getDefaultAvatar()}" alt="" />
                        <div class="cinfo">
                            <div class="cname">${u.username} ${u.isOnline ? '🟢' : ''}</div>
                            <div class="cmsg">${msgPreview.length > 40 ? msgPreview.slice(0,40)+'…' : msgPreview}</div>
                        </div>
                        <div class="ctime">${time}</div>
                    </div>
                `;
            });
            container.innerHTML = html;
        }

        window.openChat = function(userId) {
            const users = DB.getUsers();
            const target = users.find(u => u.id === userId);
            if (!target) return;
            currentChatTarget = target;
            document.getElementById('chatTargetAvatar').src = target.profilePic || getDefaultAvatar();
            document.getElementById('chatTargetName').textContent = target.username;
            document.getElementById('chatModal').classList.add('open');
            renderChatMessages(userId);
        };

        function renderChatMessages(userId) {
            const container = document.getElementById('chatMessages');
            const messages = DB.getMessages().filter(m =>
                (m.fromUserId === currentUser.id && m.toUserId === userId) ||
                (m.fromUserId === userId && m.toUserId === currentUser.id)
            ).sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt));

            if (messages.length === 0) {
                container.innerHTML =
                    `<div style="text-align:center;padding:24px;color:#6a7a8a;">No messages yet. Say hello! 👋</div>`;
                return;
            }
            let html = '';
            messages.forEach(m => {
                const isSent = m.fromUserId === currentUser.id;
                html += `
                    <div class="msg ${isSent ? 'sent' : 'received'}">
                        ${m.content}
                        <span class="msg-time">${timeAgo(m.createdAt)}</span>
                    </div>
                `;
            });
            container.innerHTML = html;
            container.scrollTop = container.scrollHeight;
        }

        document.getElementById('sendChatBtn').addEventListener('click', () => {
            const input = document.getElementById('chatInput');
            const text = input.value.trim();
            if (!text || !currentChatTarget) return;
            const messages = DB.getMessages();
            messages.push({
                id: generateId(),
                fromUserId: currentUser.id,
                toUserId: currentChatTarget.id,
                content: text,
                createdAt: new Date().toISOString(),
                read: false
            });
            DB.setMessages(messages);
            input.value = '';
            renderChatMessages(currentChatTarget.id);
            renderChatList();
            // update notification badge
            updateNotifBadge();
        });

        document.getElementById('chatInput').addEventListener('keydown', e => {
            if (e.key === 'Enter') document.getElementById('sendChatBtn').click();
        });

        document.getElementById('closeChatModal').addEventListener('click', () => {
            document.getElementById('chatModal').classList.remove('open');
        });
        document.getElementById('chatModal').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('open');
        });

        // ============================================================
        //  VIDEOS TAB
        // ============================================================
        function renderVideos() {
            const container = document.getElementById('videoGrid');
            if (!container) return;
            const posts = DB.getPosts().filter(p => p.type === 'video' && p.videoUrl);
            if (posts.length === 0) {
                container.innerHTML =
                    `<div class="empty-state" style="grid-column:1/-1;"><i class="fas fa-video"></i><h3>No videos yet</h3><p>Share a video with the community!</p></div>`;
                return;
            }
            let html = '';
            posts.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt)).forEach(p => {
                html += `
                    <div class="video-card">
                        <div class="video-placeholder">
                            <video controls style="width:100%;height:100%;object-fit:cover;background:#000;" poster="">
                                <source src="${p.videoUrl}" type="video/mp4" />
                            </video>
                        </div>
                        <div class="video-info">
                            <h4>${p.content.length > 30 ? p.content.slice(0,30)+'…' : p.content}</h4>
                            <p>By ${p.username} • ${timeAgo(p.createdAt)}</p>
                        </div>
                    </div>
                `;
            });
            container.innerHTML = html;
        }

        // ============================================================
        //  PROFILE MODAL
        // ============================================================
        document.getElementById('profileSettingsBtn').addEventListener('click', () => {
            const user = currentUser;
            document.getElementById('profileUsername').value = user.username || '';
            document.getElementById('profileBio').value = user.bio || '';
            document.getElementById('profileLocation').value = user.location || '';
            document.getElementById('profileInterests').value = user.interests || '';
            document.getElementById('profileModal').classList.add('open');
        });

        document.getElementById('closeProfileModal').addEventListener('click', () => {
            document.getElementById('profileModal').classList.remove('open');
        });
        document.getElementById('profileModal').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('open');
        });

        document.getElementById('saveProfileBtn').addEventListener('click', () => {
            const users = DB.getUsers();
            const user = users.find(u => u.id === currentUser.id);
            if (!user) return;
            user.username = document.getElementById('profileUsername').value.trim() || user.username;
            user.bio = document.getElementById('profileBio').value.trim();
            user.location = document.getElementById('profileLocation').value.trim();
            user.interests = document.getElementById('profileInterests').value.trim();
            DB.setUsers(users);
            DB.setCurrentUser(user);
            currentUser = user;
            // Update header
            document.getElementById('dashUsername').textContent = user.username;
            document.getElementById('profileModal').classList.remove('open');
            // Re-render
            renderPosts();
            renderOnlineUsers(currentYearFilter);
            renderChatList();
        });

        // ============================================================
        //  NAVIGATION TABS
        // ============================================================
        document.querySelectorAll('.nav-item[data-tab]').forEach(item => {
            item.addEventListener('click', function() {
                const tab = this.dataset.tab;
                // Update sidebar
                document.querySelectorAll('.nav-item[data-tab]').forEach(el => el.classList.remove('active'));
                this.classList.add('active');
                // Update mobile nav
                document.querySelectorAll('.mnav-item').forEach(el => el.classList.remove('active'));
                document.querySelector(`.mnav-item[data-tab="${tab}"]`)?.classList.add('active');
                // Show panel
                document.querySelectorAll('.tab-panel').forEach(el => el.classList.remove('active'));
                const panel = document.getElementById(`tab-${tab}`);
                if (panel) panel.classList.add('active');
                // Re-render content for some tabs
                if (tab === 'posts') renderPosts('allPostsContainer');
                if (tab === 'chats') renderChatList();
                if (tab === 'videos') renderVideos();
            });
        });

        document.querySelectorAll('.mnav-item').forEach(item => {
            item.addEventListener('click', function() {
                const tab = this.dataset.tab;
                document.querySelectorAll('.mnav-item').forEach(el => el.classList.remove('active'));
                this.classList.add('active');
                document.querySelectorAll('.nav-item[data-tab]').forEach(el => el.classList.remove('active'));
                document.querySelector(`.nav-item[data-tab="${tab}"]`)?.classList.add('active');
                document.querySelectorAll('.tab-panel').forEach(el => el.classList.remove('active'));
                const panel = document.getElementById(`tab-${tab}`);
                if (panel) panel.classList.add('active');
                if (tab === 'posts') renderPosts('allPostsContainer');
                if (tab === 'chats') renderChatList();
                if (tab === 'videos') renderVideos();
            });
        });

        // ============================================================
        //  LOGOUT
        // ============================================================
        document.getElementById('logoutBtn').addEventListener('click', () => {
            const users = DB.getUsers();
            const user = users.find(u => u.id === currentUser.id);
            if (user) {
                user.isOnline = false;
                user.lastSeen = new Date().toISOString();
                DB.setUsers(users);
            }
            DB.clearSession();
            currentUser = null;
            switchPage('loginPage');
            document.getElementById('loginEmail').value = '';
            document.getElementById('loginPassword').value = '';
        });

        // ============================================================
        //  NOTIFICATIONS BADGE
        // ============================================================
        function updateNotifBadge() {
            const messages = DB.getMessages();
            const unread = messages.filter(m => m.toUserId === currentUser.id && !m.read).length;
            const badge = document.getElementById('notifBadge');
            if (badge) {
                badge.textContent = unread;
                badge.style.display = unread > 0 ? 'flex' : 'none';
            }
        }

        document.getElementById('notifBtn').addEventListener('click', () => {
            // Mark all as read
            const messages = DB.getMessages();
            messages.forEach(m => {
                if (m.toUserId === currentUser.id) m.read = true;
            });
            DB.setMessages(messages);
            updateNotifBadge();
            alert('📬 All notifications marked as read!');
        });

        // ============================================================
        //  AUTO-REFRESH ONLINE STATUS (simulate)
        // ============================================================
        setInterval(() => {
            // Randomly toggle some users online/offline for demo
            const users = DB.getUsers();
            users.forEach(u => {
                if (u.id !== currentUser?.id) {
                    // 10% chance to toggle
                    if (Math.random() < 0.05) {
                        u.isOnline = !u.isOnline;
                        u.lastSeen = new Date().toISOString();
                    }
                }
            });
            DB.setUsers(users);
            // Re-render online users if dashboard is active
            if (document.getElementById('dashboardPage').classList.contains('active')) {
                renderOnlineUsers(currentYearFilter);
                renderChatList();
                updateNotifBadge();
            }
        }, 15000);

        // ============================================================
        //  INIT — check session
        // ============================================================
        (function init() {
            const session = DB.getCurrentUser();
            if (session) {
                // Verify user still exists
                const users = DB.getUsers();
                const found = users.find(u => u.id === session.id);
                if (found) {
                    found.isOnline = true;
                    found.lastSeen = new Date().toISOString();
                    DB.setUsers(users);
                    DB.setCurrentUser(found);
                    enterDashboard(found);
                    return;
                }
            }
            // Show login
            switchPage('loginPage');
        })();

        // ============================================================
        //  PROFILE PIC UPLOAD PREVIEW (signup)
        // ============================================================
        document.getElementById('profilePicInput').addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const preview = document.getElementById('avatarPreview');
                    preview.innerHTML = `<img src="${e.target.result}" alt="avatar" />`;
                };
                reader.readAsDataURL(this.files[0]);
            }
        });

        // ============================================================
        //  KEYBOARD SHORTCUTS
        // ============================================================
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal-overlay.open').forEach(el => el.classList.remove('open'));
            }
        });

        console.log('Mzuzu Hub loaded successfully!');
        console.log('Developed by Emmanuel Chimombo — Mzuzu University');
    </script>
</body>
</html>
